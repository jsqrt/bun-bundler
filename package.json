{
	"description": "A fast, zero-config-friendly bundler for HTML/Pug, SCSS/CSS, and JavaScript projects.",
	"author": "jsqrt",
	"license": "MIT",
	"name": "bun-bundler",
	"version": "0.2.13",
	"type": "module",
	"engines": {
		"bun": ">=1.0.0"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"bun-bundler": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./modules": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "bun run build.ts",
		"prepublishOnly": "bun run build",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"test:html": "cd examples/html-boilerplate && bun run build",
		"test:pug": "cd examples/pug-boilerplate && bun run build"
	},
	"dependencies": {
		"browser-sync": "^3.0.2",
		"cross-env": "^7.0.3",
		"effect": "^3.13.2",
		"jsdom": "^24.1.0",
		"ora": "^9.0.0",
		"pug": "^3.0.3",
		"sass": "^1.77.6",
		"sharp": "^0.34.5",
		"typescript": "^5.7.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jsqrt/bun-bundler.git"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"configFileName": "bundler.config.json",
	"devDependencies": {
		"@types/bun": "^1.3.2",
		"@types/node": "^24.10.0",
		"tsx": "^4.20.6",
		"vitest": "^4.0.8"
	}
}
