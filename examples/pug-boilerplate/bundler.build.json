{
	"mode": "build",
	"bundler": {
		"dist": "./build",
		"sass": "./src/scss/app.scss",
		"cssDist": "./build/css/",
		"js": "./src/js/app.js",
		"jsDist": "./build/js/",
		"html": "./src/pug/",
		"htmlDist": "./build",
		"staticFolders": [
			"./src/images/",
			"./src/fonts/",
			"./src/static/"
		],
		"assembleStyles": "./build/css/app.css",
		"production": true,
		"debug": false
	},
	"imageProcessor": {
		"entry": "./build/images",
		"keepOriginals": false
	},
	"spriteBuilder": {
		"dist": "./build/images/sprite/sprite.svg",
		"entry": "./build/",
		"spriteIconSelector": "svg[data-sprite-icon]",
		"additionalIcons": "./src/images/facebook.svg"
	}
}
