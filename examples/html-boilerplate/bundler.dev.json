{
	"mode": "dev",
	"bundler": {
		"dist": "./dist",
		"sass": "./src/css/app.css",
		"cssDist": "./dist/css/",
		"js": "./src/js/app.js",
		"jsDist": "./dist/js/",
		"html": "./src/html/",
		"htmlDist": "./dist",
		"staticFolders": [
			"./src/images/",
			"./src/fonts/",
			"./src/static/"
		],
		"assembleStyles": "./dist/css/app.css",
		"debug": true
	},
	"server": {
		"root": "./dist",
		"open": true,
		"port": 8080
	},
	"imageProcessor": {
		"entry": "./dist/images"
	},
	"spriteBuilder": {
		"dist": "./dist/images/sprite/sprite.svg",
		"entry": "./dist/",
		"spriteIconSelector": "svg[data-sprite-icon]",
		"additionalIcons": "./src/images/facebook.svg"
	}
}
